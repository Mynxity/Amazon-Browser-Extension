{
  "manifest_version": 3,
  "name": "Amazon Listing Validator",
  "version": "1.0.0",
  "description": "Analyze Amazon listings for risk and validity using AI.",
  
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage"
  ],

  "host_permissions": [
    "https://*.amazon.com/*",
    "https://myapi.vercel.app/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Check Amazon Listing"
  },

  "content_scripts": [
    {
      "matches": ["https://*.amazon.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
